# Canadian Spirit Social Media Manager
NODE_ENV=production
PORT=5000

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_key_here

# OpenAI (for tweet generation)
OPENAI_API_KEY=your_openai_key_here

# X / Twitter API — YOUR PERSONAL ACCOUNT
TWITTER_API_KEY=your_key_here
TWITTER_API_SECRET=your_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Admin
ADMIN_API_KEY=generate_a_random_string_here
INTERNAL_SECRET=generate_another_random_string_here

# Disable all other platforms
ENABLE_SMS=false
ENABLE_EMAIL=false
ENABLE_TELEGRAM=false
ENABLE_WHATSAPP=false
ENABLE_VIDEO_GEN=false
